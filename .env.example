# ── OpenAI (untuk generate komentar & DM outreach) ───────────────────────────
OPENAI_API_KEY=sk-...

# ── Path ke session Facebook (export dari laptop) ─────────────────────────────
FB_SESSION_PATH=data/fb_session.json

# ── Path ke database bantukos-bot (listing yang akan ditawarkan) ──────────────
# Di server (Coolify): di-mount dari bantukos-bot volume → /app/bantukos.db
# Di lokal: ../bantukos-bot/data/bantukos.db
BANTUKOS_DB_PATH=bantukos.db

# ── Outreach SupportKos ───────────────────────────────────────────────────────
# URL notify endpoint WA bot (internal Docker network)
WA_NOTIFY_URL=http://bantukos-wa-bot:3001/notify
# Maks notif outreach per hari (default 10)
MAX_LEADS_PER_DAY=10
